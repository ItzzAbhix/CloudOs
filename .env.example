TZ=Asia/Kolkata

# Host and access
PUBLIC_DOMAIN=cloudos.local
N8N_HOST=n8n.cloudos.local
N8N_PROTOCOL=https
N8N_PORT=5678
NPM_ADMIN_EMAIL=admin@example.com
CLOUDOS_CORS_ORIGIN=http://localhost:4173
CLOUDOS_JWT_SECRET=replace-with-a-long-random-jwt-secret
CLOUDOS_API_PORT=4000
CLOUDOS_WEB_PORT=8088
CLOUDOS_VPN_REMOTE_URL=http://35.200.152.165:5000
CLOUDOS_VPN_AGENT_TOKEN=replace-with-a-shared-vpn-agent-token
WG_INTERFACE=wg0
WG_CONFIG_PATH=/etc/wireguard/wg0.conf
WG_DEFAULT_DNS=1.1.1.1, 1.0.0.1
WG_DEFAULT_ALLOWED_IPS=0.0.0.0/0
WG_SERVER_ENDPOINT=
WG_REFRESH_SECONDS=10
WG_USE_SUDO=0
WG_DASHBOARD_SECRET=replace-with-a-long-random-secret
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=admin123
DASHBOARD_PASSWORD_HASH=
WG_AGENT_TOKEN=replace-with-the-same-shared-vpn-agent-token

# Strong secrets required before deployment
N8N_ENCRYPTION_KEY=replace-with-a-long-random-secret
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=replace-with-a-strong-password

# Optional n8n defaults
WEBHOOK_URL=https://n8n.cloudos.local/
GENERIC_TIMEZONE=Asia/Kolkata
