TZ=Asia/Kolkata

# Host and access
PUBLIC_DOMAIN=cloudos.local
N8N_HOST=n8n.cloudos.local
N8N_PROTOCOL=https
N8N_PORT=5678
NPM_ADMIN_EMAIL=admin@example.com
CLOUDOS_CORS_ORIGIN=http://localhost:4173
CLOUDOS_JWT_SECRET=replace-with-a-long-random-jwt-secret
CLOUDOS_API_PORT=4000
CLOUDOS_WEB_PORT=8088

# Strong secrets required before deployment
N8N_ENCRYPTION_KEY=replace-with-a-long-random-secret
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=replace-with-a-strong-password

# Optional n8n defaults
WEBHOOK_URL=https://n8n.cloudos.local/
GENERIC_TIMEZONE=Asia/Kolkata
